<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="pos_screen_layout.PaymentScreen" t-inherit="point_of_sale.PaymentScreen" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('main-content')]" position="attributes">
            <attribute name="t-attf-class">main-content d-flex gap-2 h-100 bg-100 overflow-auto {{ pos.config.swap_panes ? 'flex-row-reverse' : '' }}</attribute>
        </xpath>
    </t>
</templates>
