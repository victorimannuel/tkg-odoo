<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <template
        id="report_general_ledger_base_inherit_total"
        inherit_id="account_financial_report.report_general_ledger_base"
    >
        <xpath expr="//div[@class='page']/t[@t-foreach='general_ledger']" position="after">
            <t t-if="gl_totals and gl_totals['has_accounts']">
                <div class="page_break">
                    <div class="act_as_table list_table" style="width: 100%; margin-top: 10px;">
                        <div class="act_as_row labels" style="font-weight: bold;">
                            <div class="act_as_cell first_column" style="width: 40.5%;">All Accounts</div>
                            <div class="act_as_cell right" style="width: 16%;">Grand total</div>
                            <t t-if="show_cost_center">
                                <div class="act_as_cell" style="width: 8.03%;" />
                            </t>
                            <t t-if="show_analytic_tags">
                                <div class="act_as_cell" style="width: 4.75%;" />
                            </t>
                            <div class="act_as_cell" style="width: 2.41%;" />
                            <div class="act_as_cell amount" style="width: 8.6%;">
                                <span
                                    t-out="gl_totals['fin_debit']"
                                    t-options="{'widget': 'monetary', 'display_currency': company_currency}"
                                />
                            </div>
                            <div class="act_as_cell amount" style="width: 8.02%;">
                                <span
                                    t-out="gl_totals['fin_credit']"
                                    t-options="{'widget': 'monetary', 'display_currency': company_currency}"
                                />
                            </div>
                            <div class="act_as_cell amount" style="width: 8.02%;">
                                <span
                                    t-out="gl_totals['fin_balance']"
                                    t-options="{'widget': 'monetary', 'display_currency': company_currency}"
                                />
                            </div>
                            <t t-if="foreign_currency">
                                <div class="act_as_cell" style="width: 3.63%;" />
                                <div class="act_as_cell" style="width: 3.63%;" />
                            </t>
                        </div>
                    </div>
                </div>
            </t>
        </xpath>
    </template>
</odoo>
