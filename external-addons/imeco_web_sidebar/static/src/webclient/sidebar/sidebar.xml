				</ul>
				<div t-if="sidebarImageUrl" class="sidebar_logo p-2">
					<img class="img-fluid mx-auto" t-att-src="sidebarImageUrl" alt="Logo"/>
				</div>
			</div>
		</div>
	</t>
    <t t-name="imeco_web_sidebar.SideBar.RootSection">
        <li
            t-attf-class="nav-item {{ this._isSectionActive(section) ? 'active' : '' }} {{ section.childrenTree.length ? 'has-children' : '' }} {{ this.state.openSectionId === section.id ? 'is-open' : '' }}"
        >
            <a
                t-att-href="section.href"
                t-att-data-menu-id="section.id"
                t-att-data-menu-xmlid="section.xmlid"
                t-att-data-action-id="section.actionID"
                t-on-click.prevent="() => this._onRootSectionClick(section)"
                class="nav-link"
                role="menuitem"
            >
                <span class="sidebar_name">
                    <t t-out="section.name" />
                </span>
            </a>
            <t t-if="section.childrenTree.length and this.state.openSectionId === section.id">
                <div class="sidebar_flyout">
                    <ul class="sidebar_submenu">
                        <t t-foreach="section.childrenTree" t-as="child" t-key="child.id">
                            <t t-call="imeco_web_sidebar.SideBar.Section">
                                <t t-set="section" t-value="child" />
                            </t>
                        </t>
                    </ul>
                </div>
            </t>
        </li>
    </t>
	<t t-name="imeco_web_sidebar.SideBar.Section">
        <li
            t-attf-class="nav-item {{ this._isSectionActive(section) ? 'active' : '' }} {{ section.childrenTree.length ? 'has-children' : '' }}"
        >
            <a
                t-att-href="section.href"
                t-att-data-menu-id="section.id"
                t-att-data-menu-xmlid="section.xmlid"
                t-att-data-action-id="section.actionID"
                t-on-click.prevent="() => this._onSectionClick(section)"
                class="nav-link"
                role="menuitem"
            >
                <span class="sidebar_name">
                    <t t-out="section.name" />
                </span>
            </a>
            <t t-if="section.childrenTree.length">
                <ul class="sidebar_submenu">
                    <t t-foreach="section.childrenTree" t-as="child" t-key="child.id">
                        <t t-call="imeco_web_sidebar.SideBar.Section">
                            <t t-set="section" t-value="child" />
                        </t>
                    </t>
                </ul>
            </t>
        </li>
    </t>
	
</templates>
