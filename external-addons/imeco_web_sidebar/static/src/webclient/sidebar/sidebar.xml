	<t t-name="imeco_web_sidebar.SideBar">
		<div class="sidebar_panel">
			<div class="sidebar">
				<ul class="sidebar_menu">
                    <t t-set="currentAppId" t-value="this.appMenuService.getCurrentApp()?.id" />
                    <t t-foreach="this.appMenuService.getAppSections(currentAppId)" t-as="section" t-key="section.id">
                        <t t-call="imeco_web_sidebar.SideBar.RootSection">
                            <t t-set="section" t-value="section" />
                        </t>
                    </t>

