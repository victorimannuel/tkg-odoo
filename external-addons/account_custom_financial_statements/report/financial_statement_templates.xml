<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <template id="pl">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2>Profit and Loss</h2>
                        <p>
                            <strong>Company:</strong>
                            <span t-out="o.company_id.display_name" />
                            <br />
                            <strong>Period:</strong>
                            <span t-out="o.date_from" t-options="{'widget': 'date'}" />
                            -
                            <span t-out="o.date_to" t-options="{'widget': 'date'}" />
                        </p>
                        <table class="table table-sm o_main_table">
                            <thead>
                                <tr>
                                    <th>Description</th>
                                    <th class="text-end">Amount</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="data['sections']" t-as="section">
                                    <tr>
                                        <td>
                                            <details open="open">
                                                <summary>
                                                    <strong t-out="section['label']" />
                                                </summary>
                                                <table
                                                    class="table table-sm"
                                                    style="margin: 8px 0 0 18px; width: calc(100% - 18px);"
                                                    t-if="section['lines']"
                                                >
                                                    <tbody>
                                                        <tr t-foreach="section['lines']" t-as="line">
                                                            <td style="border-top: none;">
                                                                <span t-out="line['label']" />
                                                            </td>
                                                            <td class="text-end" style="border-top: none;">
                                                                <span
                                                                    t-out="line['amount']"
                                                                    t-options="{'widget': 'monetary', 'display_currency': currency}"
                                                                />
                                                            </td>
                                                        </tr>
                                                    </tbody>
                                                </table>
                                            </details>
                                        </td>
                                        <td class="text-end">
                                            <span
                                                t-out="section['amount']"
                                                t-options="{'widget': 'monetary', 'display_currency': currency}"
                                            />
                                        </td>
                                    </tr>
                                </t>
                                <tr>
                                    <td><strong>Total Revenue</strong></td>
                                    <td class="text-end">
                                        <strong
                                            t-out="data['total_revenue']"
                                            t-options="{'widget': 'monetary', 'display_currency': currency}"
                                        />
                                    </td>
                                </tr>
                                <tr>
                                    <td><strong>Total Expense</strong></td>
                                    <td class="text-end">
                                        <strong
                                            t-out="data['total_expense']"
                                            t-options="{'widget': 'monetary', 'display_currency': currency}"
                                        />
                                    </td>
                                </tr>
                                <tr>
                                    <td><strong>Net Profit</strong></td>
                                    <td class="text-end">
                                        <strong
                                            t-out="data['net_profit']"
                                            t-options="{'widget': 'monetary', 'display_currency': currency}"
                                        />
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </t>
            </t>
        </t>
    </template>

    <template id="bs">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2>Balance Sheet</h2>
                        <p>
                            <strong>Company:</strong>
                            <span t-out="o.company_id.display_name" />
                            <br />
                            <strong>As of:</strong>
                            <span t-out="o.date_to" t-options="{'widget': 'date'}" />
                        </p>
                        <div class="row">
                            <div class="col-6">
                                <table class="table table-sm o_main_table">
                                    <thead>
                                        <tr>
                                            <th>Assets</th>
                                            <th class="text-end">Amount</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="data['asset_sections']" t-as="section">
                                            <tr>
                                                <td>
                                                    <details open="open">
                                                        <summary>
                                                            <strong t-out="section['label']" />
                                                        </summary>
                                                        <table
                                                            class="table table-sm"
                                                            style="margin: 8px 0 0 18px; width: calc(100% - 18px);"
                                                            t-if="section['lines']"
                                                        >
                                                            <tbody>
                                                                <tr t-foreach="section['lines']" t-as="line">
                                                                    <td style="border-top: none;">
                                                                        <span t-out="line['label']" />
                                                                    </td>
                                                                    <td class="text-end" style="border-top: none;">
                                                                        <span
                                                                            t-out="line['amount']"
                                                                            t-options="{'widget': 'monetary', 'display_currency': currency}"
                                                                        />
                                                                    </td>
                                                                </tr>
                                                            </tbody>
                                                        </table>
                                                    </details>
                                                </td>
                                                <td class="text-end">
                                                    <span
                                                        t-out="section['amount']"
                                                        t-options="{'widget': 'monetary', 'display_currency': currency}"
                                                    />
                                                </td>
                                            </tr>
                                        </t>
                                        <tr>
                                            <td><strong>Total Assets</strong></td>
                                            <td class="text-end">
                                                <strong
                                                    t-out="data['total_assets']"
                                                    t-options="{'widget': 'monetary', 'display_currency': currency}"
                                                />
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                            <div class="col-6">
                                <table class="table table-sm o_main_table">
                                    <thead>
                                        <tr>
                                            <th>Liabilities and Equity</th>
                                            <th class="text-end">Amount</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="data['liability_sections']" t-as="section">
                                            <tr>
                                                <td>
                                                    <details open="open">
                                                        <summary>
                                                            <strong t-out="section['label']" />
                                                        </summary>
                                                        <table
                                                            class="table table-sm"
                                                            style="margin: 8px 0 0 18px; width: calc(100% - 18px);"
                                                            t-if="section['lines']"
                                                        >
                                                            <tbody>
                                                                <tr t-foreach="section['lines']" t-as="line">
                                                                    <td style="border-top: none;">
                                                                        <span t-out="line['label']" />
                                                                    </td>
                                                                    <td class="text-end" style="border-top: none;">
                                                                        <span
                                                                            t-out="line['amount']"
                                                                            t-options="{'widget': 'monetary', 'display_currency': currency}"
                                                                        />
                                                                    </td>
                                                                </tr>
                                                            </tbody>
                                                        </table>
                                                    </details>
                                                </td>
                                                <td class="text-end">
                                                    <span
                                                        t-out="section['amount']"
                                                        t-options="{'widget': 'monetary', 'display_currency': currency}"
                                                    />
                                                </td>
                                            </tr>
                                        </t>
                                        <tr>
                                            <td><strong>Total Liabilities</strong></td>
                                            <td class="text-end">
                                                <strong
                                                    t-out="data['total_liabilities']"
                                                    t-options="{'widget': 'monetary', 'display_currency': currency}"
                                                />
                                            </td>
                                        </tr>
                                        <t t-foreach="data['equity_sections']" t-as="section">
                                            <tr>
                                                <td>
                                                    <details open="open">
                                                        <summary>
                                                            <strong t-out="section['label']" />
                                                        </summary>
                                                        <table
                                                            class="table table-sm"
                                                            style="margin: 8px 0 0 18px; width: calc(100% - 18px);"
                                                            t-if="section['lines']"
                                                        >
                                                            <tbody>
                                                                <tr t-foreach="section['lines']" t-as="line">
                                                                    <td style="border-top: none;">
                                                                        <span t-out="line['label']" />
                                                                    </td>
                                                                    <td class="text-end" style="border-top: none;">
                                                                        <span
                                                                            t-out="line['amount']"
                                                                            t-options="{'widget': 'monetary', 'display_currency': currency}"
                                                                        />
                                                                    </td>
                                                                </tr>
                                                            </tbody>
                                                        </table>
                                                    </details>
                                                </td>
                                                <td class="text-end">
                                                    <span
                                                        t-out="section['amount']"
                                                        t-options="{'widget': 'monetary', 'display_currency': currency}"
                                                    />
                                                </td>
                                            </tr>
                                        </t>
                                        <tr>
                                            <td><strong>Total Equity</strong></td>
                                            <td class="text-end">
                                                <strong
                                                    t-out="data['total_equity']"
                                                    t-options="{'widget': 'monetary', 'display_currency': currency}"
                                                />
                                            </td>
                                        </tr>
                                        <tr>
                                            <td><strong>Total Liabilities + Equity</strong></td>
                                            <td class="text-end">
                                                <strong
                                                    t-out="data['total_liabilities_equity']"
                                                    t-options="{'widget': 'monetary', 'display_currency': currency}"
                                                />
                                            </td>
                                        </tr>
                                        <tr>
                                            <td><strong>Difference</strong></td>
                                            <td class="text-end">
                                                <strong
                                                    t-out="data['difference']"
                                                    t-options="{'widget': 'monetary', 'display_currency': currency}"
                                                />
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
