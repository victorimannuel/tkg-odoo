<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_custom_bs_mapping_tree" model="ir.ui.view">
        <field name="name">custom.bs.mapping.tree</field>
        <field name="model">custom.bs.mapping</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence" />
                <field name="company_id" groups="base.group_multi_company" />
                <field name="side" />
                <field name="line_mode" />
                <field name="name" />
                <field name="account_ids" widget="many2many_tags" optional="hide" />
                <field name="group_ids" widget="many2many_tags" optional="hide" />
                <field name="active" />
            </list>
        </field>
    </record>

    <record id="view_custom_bs_mapping_form" model="ir.ui.view">
        <field name="name">custom.bs.mapping.form</field>
        <field name="model">custom.bs.mapping</field>
        <field name="arch" type="xml">
            <form string="Balance Sheet Mapping">
                <sheet>
                    <group>
                        <field name="company_id" groups="base.group_multi_company" />
                        <field name="sequence" />
                        <field name="side" />
                        <field name="line_mode" />
                        <field name="name" />
                        <field name="active" />
                    </group>
                    <group invisible="line_mode != 'accounts'">
                        <field name="account_ids" widget="many2many_tags" />
                        <field name="group_ids" widget="many2many_tags" />
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_custom_bs_mapping" model="ir.actions.act_window">
        <field name="name">Balance Sheet Mapping</field>
        <field name="res_model">custom.bs.mapping</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_custom_bs_mapping"
        name="Balance Sheet Mapping"
        parent="account.menu_finance_configuration"
        action="action_custom_bs_mapping"
        sequence="80"
        groups="account.group_account_manager"
    />
</odoo>
