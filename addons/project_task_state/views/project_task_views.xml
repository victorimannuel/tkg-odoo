<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_task_kanban_inherit_state" model="ir.ui.view">
        <field name="name">project.task.kanban.inherit.state</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_kanban"/>
        <field name="arch" type="xml">
            <xpath expr="//progressbar[@field='state']" position="replace">
                <progressbar field="state" colors='{"1_done": "success-done", "1_canceled": "danger", "03_approved": "success", "02_changes_requested": "purple", "04_waiting_normal": "info", "01_in_progress": "info", "05_pending": "warning", "06_waiting_validation": "warning"}'/>
            </xpath>
        </field>
    </record>

    <record id="project_sharing_project_task_view_kanban_inherit_state" model="ir.ui.view">
        <field name="name">project.sharing.project.task.view.kanban.inherit.state</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.project_sharing_project_task_view_kanban"/>
        <field name="arch" type="xml">
            <xpath expr="//progressbar[@field='state']" position="replace">
                <progressbar field="state" colors='{"1_done": "success-done", "1_canceled": "danger", "03_approved": "success", "02_changes_requested": "purple", "04_waiting_normal": "info", "01_in_progress": "info", "05_pending": "warning", "06_waiting_validation": "warning"}'/>
            </xpath>
        </field>
    </record>
</odoo>
