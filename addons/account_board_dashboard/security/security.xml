<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="group_account_board_dashboard" model="res.groups">
        <field name="name">Board Accounting Dashboard</field>
        <field name="implied_ids" eval="[(4, ref('account.group_account_user'))]"/>
    </record>

    <record id="rule_account_board_kpi_summary_company" model="ir.rule">
        <field name="name">Board KPI Summary multi-company</field>
        <field name="model_id" ref="model_account_board_kpi_summary"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('account_board_dashboard.group_account_board_dashboard'))]"/>
    </record>

    <record id="rule_account_board_kpi_monthly_company" model="ir.rule">
        <field name="name">Board KPI Monthly multi-company</field>
        <field name="model_id" ref="model_account_board_kpi_monthly"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('account_board_dashboard.group_account_board_dashboard'))]"/>
    </record>

    <record id="rule_account_board_aging_company" model="ir.rule">
        <field name="name">Board Aging multi-company</field>
        <field name="model_id" ref="model_account_board_aging"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('account_board_dashboard.group_account_board_dashboard'))]"/>
    </record>
</odoo>
