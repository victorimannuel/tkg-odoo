<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-name="account_board_dashboard.AccountBoardDashboardAction">
        <div t-att-class="'o_account_board_dashboard_root ' + (state.darkMode ? 'is-dark' : '')" tabindex="0" style="height:calc(100vh - 120px);max-height:calc(100vh - 120px);overflow-y:auto;overflow-x:hidden;">
            <div class="o_account_board_dashboard p-3">
                <div class="dashboard-topbar mb-3">
                    <h2 class="mb-0">Accounting Board Dashboard</h2>
                    <div class="dashboard-controls">
                        <select class="form-select form-select-sm" t-on-change="(ev) => this.onChangePeriod(ev.target.value)">
                            <option value="ytd" t-att-selected="state.selectedPeriod === 'ytd'">YTD</option>
                            <option value="mtd" t-att-selected="state.selectedPeriod === 'mtd'">MTD</option>
                        </select>
                        <button class="btn btn-sm btn-outline-primary" t-on-click="onRefreshData">Refresh</button>
                        <button class="btn btn-sm btn-outline-secondary" t-on-click="exportSnapshotPdf">Export PDF</button>
                    </div>
                </div>
                <div class="dashboard-meta mb-2" t-if="state.refreshedAt">
                    <span class="live-badge">Live as of <t t-esc="new Date(state.refreshedAt).toLocaleString()"/></span>
                    <span t-if="state.snapshotDate"> | Snapshot Date: <t t-esc="state.snapshotDate"/></span>
                </div>

                <div class="alert alert-warning mb-3" t-if="state.multiCurrencyWarning">
                    <strong>Currency Warning:</strong> <t t-esc="state.multiCurrencyWarning"/>
                </div>
                <div class="alert alert-info mb-3">
                    <strong>Business Model Note:</strong> Mixed business model (Service and Product entities) may produce different margin profiles; interpret contribution and net margins with cost structure context.
                </div>

                <t t-if="state.loading">
                    <div class="kpi-skeleton-grid mb-3">
                        <div class="kpi-skeleton" t-foreach="[1,2,3,4]" t-as="i" t-key="i"></div>
                    </div>
                </t>
                <t t-elif="state.error">
                    <div class="alert alert-danger" role="alert"><t t-esc="state.error"/></div>
                </t>
                <t t-elif="state.data">
                    <div class="kpi-strip mb-3">
                        <div t-att-class="'kpi-tile ' + ((kpi.key == 'ar' || kpi.key == 'ap') ? 'kpi-tile-clickable' : '')" t-on-click="() => this.onKpiTileClick(kpi)" t-foreach="state.headlineKpis" t-as="kpi" t-key="kpi.key">
                            <div class="kpi-label"><t t-esc="kpi.label"/> <span t-att-class="'kpi-target kpi-target-' + kpi.target.level"><t t-esc="kpi.target.label"/></span></div>
                            <div class="kpi-value" t-if="kpi.type == 'money'"><t t-esc="formatCurrency(kpi.value, kpi.currencyCode)"/></div>
                            <div class="kpi-value" t-else=""><t t-esc="Math.round((kpi.value || 0) * 100) / 100"/></div>
                            <div class="kpi-delta" t-if="kpi.key == 'ar' || kpi.key == 'ap'">Click to view entries</div>
                            <div class="kpi-delta" t-if="kpi.key == 'revenue' and state.kpiDeltas.revenueDeltaPct">MoM: <t t-esc="Math.round(state.kpiDeltas.revenueDeltaPct * 10) / 10"/>%</div>
                            <div class="kpi-delta" t-if="kpi.key == 'revenue' and state.kpiDeltas.revenueYoYPct">YoY: <t t-esc="Math.round(state.kpiDeltas.revenueYoYPct * 10) / 10"/>%</div>
                            <div class="kpi-delta" t-if="kpi.key == 'gross_profit' and state.kpiDeltas.grossProfitYoYPct">YoY: <t t-esc="Math.round(state.kpiDeltas.grossProfitYoYPct * 10) / 10"/>%</div>
                            <div class="kpi-delta" t-if="kpi.key == 'net_profit' and state.kpiDeltas.netProfitYoYPct">YoY: <t t-esc="Math.round(state.kpiDeltas.netProfitYoYPct * 10) / 10"/>%</div>
                            <div class="kpi-delta" t-if="kpi.key == 'net_profit' and state.kpiDeltas.netMarginDeltaPct">Margin Δ: <t t-esc="Math.round(state.kpiDeltas.netMarginDeltaPct * 10) / 10"/> pts</div>
                        </div>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-12 col-xl-6" t-if="state.revenueShareChart">
                            <div class="card shadow-sm">
                                <div class="card-header">Revenue Share by Company (<t t-esc="state.revenueShareChart.periodLabel"/>)</div>
                                <div class="card-body">
                                    <div class="revenue-share-layout">
                                        <div class="revenue-share-donut-wrap">
                                            <div class="revenue-share-donut" t-att-style="'background:' + state.revenueShareChart.donutStyle"></div>
                                            <div class="revenue-share-center">
                                                <div class="center-label">Total <t t-esc="state.revenueShareChart.periodLabel"/></div>
                                                <div class="center-value"><t t-esc="formatCurrency(state.revenueShareChart.total, state.revenueShareChart.currencyCode)"/></div>
                                            </div>
                                        </div>
                                        <div class="revenue-share-legend">
                                            <div class="revenue-share-item" t-foreach="state.revenueShareChart.slices" t-as="slice" t-key="slice.companyId">
                                                <span class="dot" t-att-style="'background:' + slice.color"></span>
                                                <button class="legend-link" t-on-click="() => this.onDrillRevenueShare(slice.companyId)"><t t-esc="slice.companyName"/></button>
                                                <span class="legend-percent"><t t-esc="Math.round(slice.pct * 10) / 10"/>%</span>
                                                <span class="legend-value"><t t-esc="formatCurrency(slice.value, slice.currencyCode)"/></span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-xl-6">
                            <div class="card shadow-sm">
                                <div class="card-header">Top Risk Indicators</div>
                                <div class="card-body">
                                    <div class="risk-item" t-foreach="state.riskHighlights" t-as="risk" t-key="risk.label">
                                        <div><strong><t t-esc="risk.label"/></strong></div>
                                        <div class="risk-meta">
                                            <span t-if="risk.label == 'Overdue AR 90+'"><t t-esc="formatCurrency(risk.value, (state.data.summary[0] &amp;&amp; state.data.summary[0].currency_code) || 'USD')"/> (<t t-esc="Math.round((risk.pct || 0) * 10) / 10"/>%)</span>
                                            <span t-else=""><t t-esc="Math.round((risk.value || 0) * 100) / 100"/></span>
                                            <span t-att-class="'risk-badge risk-' + risk.type"><t t-esc="risk.type.toUpperCase()"/></span>
                                        </div>
                                    </div>
                                    <button class="btn btn-link btn-sm p-0" t-on-click="onDrillOverdueAr">Drill Overdue Receivables</button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row g-3 mb-3" t-if="state.profitWaterfall">
                        <div class="col-12">
                            <div class="card shadow-sm">
                                <div class="card-header">Profit Waterfall (<t t-esc="state.profitWaterfall.periodLabel"/>)</div>
                                <div class="card-body">
                                    <div class="waterfall-chart">
                                        <div class="waterfall-row" t-foreach="state.profitWaterfall.steps" t-as="step" t-key="step.key">
                                            <div class="waterfall-label"><t t-esc="step.label"/></div>
                                            <div class="waterfall-track">
                                                <div t-att-class="'waterfall-bar waterfall-' + step.kind" t-att-style="'left:' + step.leftPct + '%;width:' + step.widthPct + '%;'"></div>
                                            </div>
                                            <div class="waterfall-value"><t t-esc="formatCurrency(step.value, state.profitWaterfall.currencyCode)"/></div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row g-3 mb-3" t-if="state.cashRunway">
                        <div class="col-12 col-xl-6">
                            <div class="card shadow-sm">
                                <div class="card-header">Cash Runway</div>
                                <div class="card-body">
                                    <div class="kpi-label">Runway Status <span t-att-class="'kpi-target kpi-target-' + (state.cashRunway.status == 'critical' ? 'bad' : (state.cashRunway.status == 'watch' ? 'warn' : 'good'))"><t t-esc="state.cashRunway.status.toUpperCase()"/></span></div>
                                    <div>Cash: <strong><t t-esc="formatCurrency(state.cashRunway.cash, state.cashRunway.currencyCode)"/></strong></div>
                                    <div>Avg Monthly OpEx: <strong><t t-esc="formatCurrency(state.cashRunway.avgMonthlyOpex, state.cashRunway.currencyCode)"/></strong></div>
                                    <div>Runway: <strong><t t-esc="Math.round(state.cashRunway.runwayMonths * 10) / 10"/> months</strong></div>
                                </div>
                            </div>
                        </div>
                        <div class="col-12 col-xl-6">
                            <div class="card shadow-sm">
                                <div class="card-header">Aging Buckets Overview</div>
                                <div class="card-body">
                                    <div class="trend-chart" t-foreach="state.agingBucketTotals" t-as="line" t-key="line.bucket">
                                        <div class="trend-label"><span><t t-esc="line.label"/></span></div>
                                        <div class="trend-bar-wrap"><div class="aging-bucket-bar" t-att-style="'width:' + line.width + '%'"/></div>
                                        <div class="trend-value"><t t-esc="formatCurrency(line.amount, (state.data.summary[0] &amp;&amp; state.data.summary[0].currency_code) || 'USD')"/></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row g-3 mb-3" t-if="state.whatChanged.length">
                        <div class="col-12">
                            <div class="card shadow-sm">
                                <div class="card-header">What Changed</div>
                                <div class="card-body">
                                    <div class="change-item" t-foreach="state.whatChanged" t-as="ch" t-key="ch.text">
                                        <span t-att-class="'change-dot change-dot-' + ch.kind"></span>
                                        <span><t t-esc="ch.text"/></span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-12">
                            <div class="card shadow-sm">
                                <div class="card-header">Consolidated Revenue &amp; Margin Trend (24M)</div>
                                <div class="card-body p-0">
                                    <table class="table table-sm mb-0">
                                        <thead>
                                            <tr><th>Month</th><th class="text-end">Revenue</th><th class="text-end">Contribution Margin</th><th class="text-end">Net Margin</th></tr>
                                        </thead>
                                        <tbody>
                                            <tr t-foreach="state.trendRows" t-as="line" t-key="line.month" t-att-class="line.netMarginPct &lt; 0 ? 'table-danger' : ''">
                                                <td><t t-esc="line.month"/></td>
                                                <td class="text-end"><t t-esc="formatCurrency(line.revenue, line.currencyCode)"/></td>
                                                <td class="text-end"><t t-esc="Math.round(line.grossMarginPct * 10) / 10"/>%</td>
                                                <td class="text-end"><t t-esc="Math.round(line.netMarginPct * 10) / 10"/>%</td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-12 col-xl-5" t-if="state.auditability">
                            <div class="card shadow-sm">
                                <div class="card-header">Auditability</div>
                                <div class="card-body">
                                    <div class="audit-meta">Snapshot Date: <strong><t t-esc="state.auditability.snapshotDate"/></strong></div>
                                    <div class="audit-meta">Refreshed: <strong><t t-esc="new Date(state.auditability.refreshedAt).toLocaleString()"/></strong></div>
                                    <div class="audit-meta mb-2">Period: <strong><t t-esc="state.auditability.period"/></strong></div>
                                    <div class="audit-check" t-foreach="state.auditability.checks" t-as="chk" t-key="chk.label">
                                        <span><t t-esc="chk.label"/></span>
                                        <span t-att-class="'audit-status audit-' + chk.status"><t t-esc="chk.status.toUpperCase()"/> (<t t-esc="Math.round(chk.gap * 100) / 100"/>)</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-12 col-xl-7" t-if="state.benchmarking.length">
                            <div class="card shadow-sm">
                                <div class="card-header">Peer Benchmarking (Group Median)</div>
                                <div class="card-body p-0">
                                    <table class="table table-sm mb-0">
                                        <thead>
                                            <tr><th>Company</th><th class="text-end">Growth</th><th class="text-end">Margin</th><th class="text-end">AR 90+</th><th class="text-end">vs Median</th></tr>
                                        </thead>
                                        <tbody>
                                            <tr t-foreach="state.benchmarking" t-as="row" t-key="row.companyId">
                                                <td><t t-esc="row.companyName"/></td>
                                                <td class="text-end"><t t-esc="Math.round(row.growthPct * 10) / 10"/>%</td>
                                                <td class="text-end"><t t-esc="Math.round(row.netMarginPct * 10) / 10"/>%</td>
                                                <td class="text-end"><t t-esc="Math.round(row.ar90Pct * 10) / 10"/>%</td>
                                                <td class="text-end benchmark-vs">G <t t-esc="(row.growthVsMedian &gt;= 0 ? '+' : '') + (Math.round(row.growthVsMedian * 10) / 10)"/> | M <t t-esc="(row.marginVsMedian &gt;= 0 ? '+' : '') + (Math.round(row.marginVsMedian * 10) / 10)"/> | AR <t t-esc="(row.ar90VsMedian &gt;= 0 ? '+' : '') + (Math.round(row.ar90VsMedian * 10) / 10)"/></td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>

                    <details class="detail-block" open="open">
                        <summary>Detailed Views</summary>
                        <div class="row g-3 mt-1">
                            <div class="col-12 col-lg-6">
                                <div class="card shadow-sm">
                                    <div class="card-header">Profitability Ranking (YTD)</div>
                                    <div class="card-body p-0">
                                        <table class="table table-sm mb-0">
                                            <thead><tr><th>Company</th><th class="text-end">Revenue</th><th class="text-end">Net Profit</th><th class="text-end">Net Margin</th></tr></thead>
                                            <tbody>
                                                <tr t-foreach="state.profitabilityRanking" t-as="line" t-key="line.companyName">
                                                    <td><t t-esc="line.companyName"/></td>
                                                    <td class="text-end"><t t-esc="formatCurrency(line.revenueYtd, line.currencyCode)"/></td>
                                                    <td class="text-end"><t t-esc="formatCurrency(line.netProfitYtd, line.currencyCode)"/></td>
                                                    <td class="text-end"><t t-esc="Math.round(line.netMarginPct * 10) / 10"/>%</td>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                            <div class="col-12 col-lg-6">
                                <div class="card shadow-sm">
                                    <div class="card-header">Decision Panel</div>
                                    <div class="card-body">
                                        <div class="decision-item" t-foreach="state.decisionPanel" t-as="item" t-key="item.action">
                                            <div class="decision-head"><strong><t t-esc="item.action"/></strong><span class="decision-owner"><t t-esc="item.owner"/></span></div>
                                            <div class="decision-impact"><t t-esc="item.impact"/></div>
                                            <div class="decision-due">Due: <t t-esc="item.due"/></div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </details>
                </t>
            </div>
        </div>
    </t>
</templates>
