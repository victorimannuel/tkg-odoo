<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- 1. Define the Full Custom Document Template -->
    <template id="report_invoice_document_custom">
        <t t-call="web.basic_layout">
            <t t-set="o" t-value="o.with_context(lang=lang)"/>
            <t t-set="address" t-value="None"/> <!-- Disable standard address block -->
            
            <div class="page" style="font-family: 'Avenir';">
                <!-- Header -->
                <div class="header">
                    <div class="row mb-5">
                        <div class="col-5">
                            <img t-if="o.company_id.logo" t-att-src="image_data_uri(o.company_id.logo)" style="max-height: 210px" alt="Logo"/>
                        </div>
                        <div class="col-7 text-start" style="padding-top: 35px;">
                            <!-- <h2 t-field="o.company_id.name" class="text-uppercase" style="color: #5F7D95; font-weight: bold;"/> -->
                            <h2 class="text-uppercase" style="color: #556766; font-weight: bold;">
                                BALI VISA &amp; CO
                            </h2>
                            <div class="text-muted">
                                <span t-field="o.company_id.street"/><br/>
                                <span t-field="o.company_id.street2" t-if="o.company_id.street2"/><br t-if="o.company_id.street2"/>
                                <span t-field="o.company_id.city"/> <span t-field="o.company_id.zip"/><br/>
                                WhatsApp +62 821-4477-7647
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- Info Grid -->
                <div class="row mb-5 mt-4" style="padding-top: 100px;">
                    <div class="col-3">
                        <strong>Billed to</strong><br/>
                        <span t-field="o.partner_id.name" class="d-block"/>
                        <span t-field="o.partner_id.street" class="d-block text-muted small"/>
                    </div>
                    <div class="col-3 text-center">
                        <strong>Date Issued</strong><br/>
                        <span t-field="o.invoice_date"/>
                    </div>
                    <div class="col-3 text-center">
                        <strong>Invoice Number</strong><br/>
                        <span t-field="o.name"/>
                    </div>
                    <div class="col-3 text-end">
                        <strong>Amount Due</strong><br/>
                        <span t-field="o.amount_residual"/>
                    </div>
                </div>
                <div class="row mb-5 mt-4">
                    <div class="col-3">
                    </div>
                    <div class="col-3 text-center">
                        <strong>Due Date</strong><br/>
                        <span t-field="o.invoice_date_due"/>
                    </div>
                    <div class="col-3 text-center">
                    </div>
                    <div class="col-3 text-end">
                    </div>
                </div>

                <!-- Invoice Lines Table -->
                <table class="table table-sm o_main_table table-borderless mt-4">
                    <thead style="border-top: 2px solid gray;">
                        <tr>
                            <th name="th_description" class="text-start fw-bold">Description</th>
                            <th name="th_priceunit" class="text-end fw-bold">Rate</th>
                            <th name="th_quantity" class="text-end fw-bold">Quantity</th>
                            <th name="th_subtotal" class="text-end fw-bold">Amount</th>
                        </tr>
                    </thead>
                    <tbody class="invoice_tbody">
                        <t t-set="current_subtotal" t-value="0"/>
                        <t t-foreach="o.invoice_line_ids.sorted(key=lambda l: (-l.sequence, l.date, l.move_name, -l.id), reverse=True)" t-as="line">
                            <t t-set="current_subtotal" t-value="current_subtotal + line.price_subtotal"/>

                            <tr t-att-class="'bg-200 fw-bold o_line_section' if line.display_type == 'line_section' else 'fst-italic o_line_note' if line.display_type == 'line_note' else ''">
                                <t t-if="line.display_type == 'product'">
                                    <td name="td_name"><span t-field="line.name"/></td>
                                    <td name="td_priceunit" class="text-end">
                                        <!--<span t-field="line.price_unit"/>-->
                                        <span t-out="line.price_unit" class="text-nowrap" t-options="{&quot;widget&quot;: &quot;monetary&quot;, &quot;display_currency&quot;: o.currency_id}"/>
                                    </td>
                                    <td name="td_quantity" class="text-end">
                                        <span t-field="line.quantity"/>
                                    </td>
                                    <td name="td_subtotal" class="text-end o_price_total">
                                        <span t-field="line.price_subtotal"/>
                                    </td>
                                </t>
                                <t t-if="line.display_type == 'line_section'">
                                    <td colspan="4">
                                        <span t-field="line.name"/>
                                    </td>
                                    <t t-set="current_section" t-value="line"/>
                                    <t t-set="current_subtotal" t-value="0"/>
                                </t>
                                <t t-if="line.display_type == 'line_note'">
                                    <td colspan="4">
                                        <span t-field="line.name"/>
                                    </td>
                                </t>
                            </tr>
                        </t>
                    </tbody>
                </table>

                <!-- Totals Section -->
                <div class="clearfix mb-4 mt-4" style="border-top: 2px solid gray;">
                    <div id="total" class="row">
                        <div class="col-7">
                            <!-- Optional left side content -->
                        </div>
                        <div class="col-5">
                            <table class="table table-sm table-borderless">
                                <tr class="border-dark fw-bold">
                                    <td>Total</td>
                                    <td class="text-end">
                                        <span t-field="o.amount_total"/>
                                    </td>
                                </tr>
                                <!-- Outstanding Due -->
                                <tr t-if="o.amount_residual" class="fw-bold" style="border-top: 2px solid gray;">
                                    <td>Outstanding Due</td>
                                    <td class="text-end">
                                        <span t-field="o.amount_residual"/>
                                    </td>
                                </tr>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- Footer / Payment Details -->
                <div class="row mt-5" style="page-break-inside: avoid;">
                    <div class="col-12">
                        <div class="pt-3">
                            <strong>Payment Details</strong>
                            <div class="row mt-2">
                                <div class="col-6">
                                    <table class="table table-sm table-borderless">
                                        <tr>
                                            <td>Bank Name</td>
                                            <td>: <span t-field="o.partner_bank_id.bank_id.name"/></td>
                                        </tr>
                                        <tr>
                                            <td>Bank Branch</td>
                                            <td>: <span t-field="o.partner_bank_id.bank_id.street2"/></td>
                                        </tr>
                                        <tr>
                                            <td>Bank/Swift Code</td>
                                            <td>: <span t-field="o.partner_bank_id.bank_id.bic"/></td>
                                        </tr>
                                        <tr>
                                            <td>Account Name</td>
                                            <td>: <span t-field="o.partner_bank_id.acc_holder_name"/></td>
                                        </tr>
                                        <tr>
                                            <td>Account Number</td>
                                            <td>: <span t-field="o.partner_bank_id.acc_number"/></td>
                                        </tr>
                                        <tr>
                                            <td>Payment Reference</td>
                                            <td>: <span t-field="o.payment_reference"/></td>
                                        </tr>
                                    </table>
                                </div>
                            </div>
                            <div class="mt-3 fw-bold">
                                - NON REFUNDABLE -
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- 2. Inherit the Main Wrapper to Call Our Custom Template -->
    <template id="report_invoice_custom" inherit_id="account.report_invoice">
        <xpath expr="//t[@t-call='account.report_invoice_document']" position="replace">
            <t t-call="bvc_invoice.report_invoice_document_custom" t-lang="lang"/>
        </xpath>
    </template>
</odoo>
