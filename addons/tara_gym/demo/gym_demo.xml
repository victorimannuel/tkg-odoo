<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Memberships -->
        <record id="plan_silver_monthly" model="gym.membership">
            <field name="name">Silver Monthly</field>
            <field name="price">30.00</field>
            <field name="duration">1</field>
            <field name="duration_uom">months</field>
        </record>

        <record id="plan_gold_monthly" model="gym.membership">
            <field name="name">Gold Monthly</field>
            <field name="price">50.00</field>
            <field name="duration">1</field>
            <field name="duration_uom">months</field>
        </record>

        <!-- Rooms -->
        <record id="room_yoga_studio" model="gym.room">
            <field name="name">Yoga Studio</field>
            <field name="capacity">20</field>
        </record>

        <record id="room_weight_area" model="gym.room">
            <field name="name">Weight Area</field>
            <field name="capacity">50</field>
        </record>

        <!-- Trainers (Partners + Users logic if needed, but simple partner for now?) 
             Wait, trainer model links to partner. -->
        <!-- We need to create partners first if we want to link them -->
        
        <!-- Assuming we can create gym.member directly which creates partners -->
        <record id="member_demo_1" model="gym.member">
            <field name="firstname">Alice</field>
            <field name="surname">Wonderland</field>
            <field name="email">alice@example.com</field>
            <field name="gender">female</field>
            <field name="dob">1990-05-15</field>
        </record>

        <record id="subscription_demo_1" model="gym.membership.subscription">
            <field name="member_id" ref="member_demo_1"/>
            <field name="membership_id" ref="plan_gold_monthly"/>
            <field name="date_start" eval="time.strftime('%Y-%m-%d')"/>
            <field name="state">running</field>
        </record>
    </data>
</odoo>
