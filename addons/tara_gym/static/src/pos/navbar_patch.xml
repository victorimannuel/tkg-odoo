<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <!-- Extend the POS Navbar -->
    <t t-name="tara_gym.Navbar" t-inherit="point_of_sale.Navbar" t-inherit-mode="extension" owl="1">
         <!-- Add a button next to the search bar on the right side -->
         <xpath expr="//div[hasclass('status-buttons')]/Input" position="before">
            <button class="btn btn-lg btn-light lh-lg text-primary ms-1 me-2" 
                    t-on-click="() => this.onClickOpenMemberProfile()">
                <i class="fa fa-fw fa-users"/>
                <span t-if="!ui.isSmall" class="ms-1">Gym Members</span>
            </button>
         </xpath>
    </t>

</templates>