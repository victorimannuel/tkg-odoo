<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="action_gym_service_booking" model="ir.actions.act_window">
            <field name="name">Service Bookings</field>
            <field name="path">gym-service-bookings</field>
            <field name="res_model">gym.service.booking</field>
            <field name="view_mode">list,form</field>
        </record>

        <record id="view_gym_service_booking_list" model="ir.ui.view">
            <field name="name">gym.service.booking.list</field>
            <field name="model">gym.service.booking</field>
            <field name="arch" type="xml">
                <list decoration-muted="state == 'canceled'" decoration-success="state == 'completed'">
                    <field name="name"/>
                    <field name="service_id"/>
                    <field name="member_id"/>
                    <field name="trainer_id"/>
                    <field name="room_id"/>
                    <field name="start_datetime"/>
                    <field name="end_datetime"/>
                    <field name="state" widget="badge"
                           decoration-success="state == 'completed'"
                           decoration-info="state == 'confirmed'"
                           decoration-warning="state == 'in_progress'"
                           decoration-danger="state == 'canceled'"/>
                </list>
            </field>
        </record>

        <record id="view_gym_service_booking_form" model="ir.ui.view">
            <field name="name">gym.service.booking.form</field>
            <field name="model">gym.service.booking</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_confirm" string="Confirm" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                        <button name="action_start" string="Start" type="object" invisible="state != 'confirmed'"/>
                        <button name="action_complete" string="Complete" type="object" invisible="state != 'in_progress'"/>
                        <button name="action_cancel" string="Cancel" type="object" invisible="state in ('completed', 'canceled')"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,in_progress,completed,canceled"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="name"/></h1>
                        </div>
                        <group>
                            <group>
                                <field name="service_id"/>
                                <field name="member_id"/>
                                <field name="trainer_id" invisible="service_id.service_type != 'pt'"/>
                                <field name="room_id" invisible="service_id.service_type != 'room'"/>
                            </group>
                            <group>
                                <field name="start_datetime"/>
                                <field name="end_datetime"/>
                                <field name="price"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
    </data>
</odoo>
