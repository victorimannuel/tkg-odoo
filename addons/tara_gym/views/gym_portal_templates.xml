<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="portal_my_home_menu_gym" name="Portal layout : Gym entries" inherit_id="portal.portal_breadcrumbs" priority="30">
        <xpath expr="//ol[hasclass('o_portal_submenu')]" position="inside">
            <li t-if="page_name == 'gym_subscription'" class="breadcrumb-item active">
                Gym Subscriptions
            </li>
            <li t-if="page_name == 'gym_trainer_session'" class="breadcrumb-item active">
                Trainer Sessions
            </li>
            <li t-if="page_name == 'gym_classes'" class="breadcrumb-item active">
                Available Classes
            </li>
        </xpath>
    </template>

    <template id="portal_my_home_gym" name="Show Gym" inherit_id="portal.portal_my_home" priority="30">
        <xpath expr="//div[hasclass('o_portal_docs')]" position="before">
             <t t-set="gym_member" t-value="request.env['gym.member'].sudo().search([('partner_id', '=', request.env.user.partner_id.id)], limit=1)"/>
             <div t-if="gym_member" class="row mb-4">
                 <div class="col-12 col-md-6 mb-3">
                     <div class="card h-100">
                         <div class="card-body text-center">
                             <h4>My Member Badge</h4>
                             <img t-att-src="'/report/barcode/?type=%s&amp;value=%s&amp;width=%s&amp;height=%s' % ('QR', gym_member.member_code, 200, 200)" style="width: 150px; height: 150px;"/>
                             <div class="mt-2">
                                 <strong><span t-esc="gym_member.member_code"/></strong>
                             </div>
                             <div class="mt-2">
                                 <a t-attf-href="/report/pdf/tara_gym.report_gym_member_badge_template/#{gym_member.id}" class="btn btn-secondary btn-sm" target="_blank">Download PDF</a>
                             </div>
                         </div>
                     </div>
                 </div>
                 <div class="col-12 col-md-6 mb-3">
                     <div class="card h-100">
                         <div class="card-body">
                             <h4>My Member Details</h4>
                             <p class="mb-1">
                                 <strong>Name:</strong>
                                 <span t-esc="gym_member.name"/>
                             </p>
                             <p class="mb-1" t-if="gym_member.gender">
                                 <strong>Gender:</strong>
                                 <span t-esc="gym_member.gender"/>
                             </p>
                             <p class="mb-1" t-if="gym_member.join_date">
                                 <strong>Join Date:</strong>
                                 <span t-field="gym_member.join_date"/>
                             </p>
                             <p class="mb-1">
                                 <strong>Membership Status:</strong>
                                 <span t-field="gym_member.membership_status"/>
                             </p>
                             <p class="mb-1" t-if="gym_member.current_subscription_membership_id">
                                 <strong>Current Plan:</strong>
                                 <span t-field="gym_member.current_subscription_membership_id.name"/>
                             </p>
                             <p class="mb-0">
                                 <strong>Checked In:</strong>
                                 <t t-if="gym_member.is_checked_in">
                                     Yes
                                 </t>
                                 <t t-else="">
                                     No
                                 </t>
                             </p>
                         </div>
                     </div>
                 </div>
             </div>
        </xpath>
        <xpath expr="//div[hasclass('o_portal_docs')]" position="inside">
            <t t-call="portal.portal_docs_entry">
                <t t-set="title">Gym Subscriptions</t>
                <t t-set="url" t-value="'/my/gym/subscriptions'"/>
                <t t-set="placeholder_count" t-value="'gym_subscription_count'"/>
            </t>
            <t t-call="portal.portal_docs_entry">
                <t t-set="title">My Classes (Trainer)</t>
                <t t-set="url" t-value="'/my/gym/trainer/sessions'"/>
                <t t-set="placeholder_count" t-value="'gym_trainer_session_count'"/>
            </t>
            <t t-call="portal.portal_docs_entry">
                <t t-set="title">Available Classes</t>
                <t t-set="url" t-value="'/my/gym/classes'"/>
                <t t-set="placeholder_count" t-value="'gym_class_count'"/>
            </t>
        </xpath>
    </template>

    <template id="portal_my_gym_subscriptions" name="My Gym Subscriptions">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>

            <t t-call="portal.portal_table">
                <thead>
                    <tr class="active">
                        <th>Reference</th>
                        <th>Plan</th>
                        <th>Start Date</th>
                        <th>End Date</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    <t t-foreach="subscriptions" t-as="sub">
                        <tr>
                            <td><span t-field="sub.name"/></td>
                            <td><span t-field="sub.membership_id.name"/></td>
                            <td><span t-field="sub.date_start"/></td>
                            <td><span t-field="sub.date_end"/></td>
                            <td><span t-field="sub.state"/></td>
                        </tr>
                    </t>
                </tbody>
            </t>
        </t>
    </template>

    <template id="portal_my_gym_no_member" name="No Member Linked">
        <t t-call="portal.portal_layout">
            <div class="alert alert-warning">
                Your account is not linked to a Gym Member profile. Please contact the front desk.
            </div>
        </t>
    </template>

    <template id="portal_my_gym_trainer_sessions" name="My Trainer Sessions">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>

            <t t-call="portal.portal_table">
                <thead>
                    <tr class="active">
                        <th>Class</th>
                        <th>Date</th>
                        <th>Room</th>
                        <th>Enrollments</th>
                        <th>Status</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    <t t-foreach="sessions" t-as="session">
                        <tr>
                            <td><span t-field="session.program_id.name"/></td>
                            <td><span t-field="session.start_datetime"/></td>
                            <td><span t-field="session.room_id.name"/></td>
                            <td><span t-field="session.enrollment_count"/> / <span t-field="session.capacity"/></td>
                            <td><span t-field="session.state"/></td>
                            <td>
                                <a t-attf-href="/my/gym/trainer/session/#{session.id}" class="btn btn-sm btn-primary">Details</a>
                            </td>
                        </tr>
                    </t>
                </tbody>
            </t>
        </t>
    </template>

    <template id="portal_my_gym_trainer_session_detail" name="Session Details">
        <t t-call="portal.portal_layout">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h3><span t-field="session.program_id.name"/></h3>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <strong>Date:</strong> <span t-field="session.start_datetime"/><br/>
                            <strong>Room:</strong> <span t-field="session.room_id.name"/><br/>
                        </div>
                        <div class="col-md-6 text-end">
                            <strong>Status:</strong> <span t-field="session.state"/><br/>
                            <strong>Capacity:</strong> <span t-field="session.enrollment_count"/> / <span t-field="session.capacity"/><br/>
                        </div>
                    </div>
                </div>
            </div>

            <h4 class="mt-4">Attendees</h4>
            <t t-if="not session.enrollment_ids">
                <div class="alert alert-info">No attendees enrolled yet.</div>
            </t>
            <table class="table table-striped mt-2" t-if="session.enrollment_ids">
                <thead>
                    <tr>
                        <th>Member</th>
                        <th>Status</th>
                        <th>Check-in Time</th>
                    </tr>
                </thead>
                <tbody>
                    <t t-foreach="session.enrollment_ids" t-as="enrollment">
                        <tr>
                            <td><span t-field="enrollment.member_id.name"/></td>
                            <td><span t-field="enrollment.state"/></td>
                            <td><span t-field="enrollment.checkin_time"/></td>
                        </tr>
                    </t>
                </tbody>
            </table>
        </t>
    </template>
    <template id="portal_my_gym_classes_list" name="Available Classes">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>

            <t t-call="portal.portal_table">
                <thead>
                    <tr class="active">
                        <th>Class</th>
                        <th>Trainer</th>
                        <th>Date</th>
                        <th>Room</th>
                        <th>Spots Left</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    <t t-foreach="sessions" t-as="session">
                        <tr>
                            <td><span t-field="session.program_id.name"/></td>
                            <td><span t-field="session.trainer_id.name"/></td>
                            <td><span t-field="session.start_datetime"/></td>
                            <td><span t-field="session.room_id.name"/></td>
                            <td>
                                <t t-esc="session.capacity - session.enrollment_count"/> / <span t-field="session.capacity"/>
                            </td>
                            <td>
                                <t t-set="is_enrolled" t-value="False"/>
                                <t t-foreach="session.enrollment_ids" t-as="enrollment">
                                    <t t-if="enrollment.member_id.id == member.id">
                                        <t t-set="is_enrolled" t-value="True"/>
                                    </t>
                                </t>

                                <t t-if="is_enrolled">
                                    <span class="badge bg-success">Enrolled</span>
                                </t>
                                <t t-else="">
                                    <form t-if="session.enrollment_count &lt; session.capacity" 
                                          t-attf-action="/my/gym/class/enroll/#{session.id}" method="POST">
                                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                        <button type="submit" class="btn btn-sm btn-primary">Book Now</button>
                                    </form>
                                    <span t-else="" class="badge bg-secondary">Full</span>
                                </t>
                            </td>
                        </tr>
                    </t>
                </tbody>
            </t>
        </t>
    </template>
</odoo>
