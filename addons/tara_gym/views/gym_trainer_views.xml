<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="action_gym_trainer" model="ir.actions.act_window">
            <field name="name">Trainers</field> 
            <field name="path">gym-trainers</field>
            <field name="res_model">gym.trainer</field>
            <field name="view_mode">kanban,list,form</field>
        </record>

        <record id="view_gym_trainer_form" model="ir.ui.view">
            <field name="name">gym.trainer.form</field>
            <field name="model">gym.trainer</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <field name="image_1920" widget="image" class="oe_avatar"/>
                        <div class="oe_title">
                            <h1><field name="name"/></h1>
                        </div>
                        <group>
                            <group>
                                <field name="partner_id" invisible="1"/>
                                <field name="email"/>
                                <field name="phone"/>
                                <field name="gender"/>
                            </group>
                            <group>
                                <field name="specialty_ids" widget="many2many_tags"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Bio">
                                <field name="bio"/>
                            </page>
                            <page string="Availability">
                                <field name="availability_ids">
                                    <list editable="bottom">
                                        <field name="day_of_week"/>
                                        <field name="start_time" widget="float_time"/>
                                        <field name="end_time" widget="float_time"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Sessions">
                                <field name="session_ids"/>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="view_gym_trainer_kanban" model="ir.ui.view">
            <field name="name">gym.trainer.kanban</field>
            <field name="model">gym.trainer</field>
            <field name="arch" type="xml">
                <kanban>
                    <field name="id"/>
                    <field name="name"/>
                    <field name="image_128"/>
                    <field name="gender"/>
                    <field name="specialty_ids"/>
                    <field name="email"/>
                    <field name="phone"/>
                    <templates>
                        <t t-name="card" class="flex-row align-items-center">
                            <aside class="me-4">
                                <div class="rounded-circle overflow-hidden" style="width:80px; height:80px;">
                                    <t t-if="record.image_128.raw_value">
                                        <field name="image_128" widget="image" alt="Trainer" options="{'img_class': 'w-100 h-100 object-fit-cover'}"/>
                                    </t>
                                    <t t-else="">
                                        <img t-if="record.gender.raw_value == 'male'" alt="Trainer" t-att-src="'/tara_gym/static/src/img/man_gym_placeholder.jpg'" class="w-100 h-100 object-fit-cover"/>
                                        <img t-elif="record.gender.raw_value == 'female'" alt="Trainer" t-att-src="'/tara_gym/static/src/img/woman_gym_placeholder.jpg'" class="w-100 h-100 object-fit-cover"/>
                                        <img t-else="" alt="Trainer" t-att-src="'/tara_gym/static/src/img/other_gym_placeholder.svg'" class="w-100 h-100 object-fit-contain"/>
                                    </t>
                                </div>
                            </aside>
                            <main>
                                <div class="oe_kanban_global_click o_kanban_record_has_image_fill">
                                    <div class="oe_kanban_details">
                                        <strong class="o_kanban_record_title">
                                            <field name="name"/>
                                        </strong>
                                        <div class="o_kanban_tags_section">
                                            <field name="specialty_ids" widget="many2many_tags"/>
                                        </div>
                                        <p style="color: gray;">
                                            <field name="email"/>
                                            <br/>
                                            <field name="phone"/>
                                        </p>
                                        <div class="o_kanban_record_bottom mt-2">
                                            <div class="oe_kanban_bottom_left"/>
                                            <div class="oe_kanban_bottom_right"/>
                                        </div>
                                    </div>
                                </div>
                            </main>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

    </data>
</odoo>
