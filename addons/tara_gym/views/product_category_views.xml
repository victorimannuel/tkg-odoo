<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="product_category_form_view_inherit_gym" model="ir.ui.view">
            <field name="name">product.category.form.inherit.gym</field>
            <field name="model">product.category</field>
            <field name="inherit_id" ref="product.product_category_form_view"/>
            <field name="arch" type="xml">
                <field name="parent_id" position="after">
                    <field name="gym_category_type"/>
                    <field name="active" widget="boolean_toggle"/>
                </field>
            </field>
        </record>

        <record id="view_gym_category_list" model="ir.ui.view">
            <field name="name">gym.category.list</field>
            <field name="model">product.category</field>
            <field name="arch" type="xml">
                <list default_order="sequence asc, complete_name asc">
                    <field name="sequence" widget="handle"/>
                    <field name="display_name" string="Category Name"/>
                    <field name="gym_category_type"/>
                    <field name="active" widget="boolean_toggle"/>
                </list>
            </field>
        </record>
    </data>
</odoo>
