<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_gym_class_enrollment_list" model="ir.ui.view">
        <field name="name">gym.class.enrollment.list</field>
        <field name="model">gym.class.enrollment</field>
        <field name="arch" type="xml">
            <list string="Class Enrollments" create="0" edit="0" delete="0">
                <field name="member_id"/>
                <field name="session_id"/>
                <field name="start_datetime" string="Start"/>
                <field name="end_datetime" string="End"/>
                <field name="state" widget="badge"
                    decoration-info="state == 'draft'"
                    decoration-success="state == 'attended'"
                    decoration-warning="state == 'confirmed'"/>
            </list>
        </field>
    </record>

    <record id="view_gym_class_enrollment_search" model="ir.ui.view">
        <field name="name">gym.class.enrollment.search</field>
        <field name="model">gym.class.enrollment</field>
        <field name="arch" type="xml">
            <search string="Search Enrollments">
                <field name="member_id"/>
            </search>
        </field>
    </record>

    <record id="action_gym_class_enrollment" model="ir.actions.act_window">
        <field name="name">Class Enrollments</field>
        <field name="res_model">gym.class.enrollment</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_gym_class_enrollment_search"/>
    </record>
</odoo>
