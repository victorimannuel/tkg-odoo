<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="action_gym_room" model="ir.actions.act_window">
            <field name="name">Rooms</field>
            <field name="path">gym-rooms</field>
            <field name="res_model">gym.room</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'active_test': False}</field>
        </record>

        <record id="view_gym_room_list" model="ir.ui.view">
            <field name="name">gym.room.list</field>
            <field name="model">gym.room</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="resource_calendar_id" optional="show"/>
                    <field name="color" widget="color_picker"/>
                    <!-- <field name="capacity"/> -->
                    <field name="active" widget="boolean_toggle" readonly="1"/>
                </list>
            </field>
        </record>

        <record id="view_gym_room_form" model="ir.ui.view">
            <field name="name">gym.room.form</field>
            <field name="model">gym.room</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <!-- <field name="capacity"/> -->
                                <field name="color" widget="color_picker"/>
                            </group>
                            <group>
                                <field name="active" widget="boolean_toggle"/>
                                <field name="resource_calendar_id"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
    </data>
</odoo>
