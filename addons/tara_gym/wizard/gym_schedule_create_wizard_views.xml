<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_gym_schedule_create_wizard_form" model="ir.ui.view">
        <field name="name">gym.schedule.create.wizard.form</field>
        <field name="model">gym.schedule.create.wizard</field>
        <field name="arch" type="xml">
            <form string="Create New Event">
                <sheet>
                    <div class="text-center mb-4">
                        <p class="text-muted">
                            Time: <field name="start_datetime" widget="datetime" readonly="1"/> 
                            - <field name="end_datetime" widget="datetime" readonly="1"/>
                        </p>
                    </div>
                    <div class="row text-center">
                        <div class="col-6">
                            <button name="action_create_class" type="object" string="ADD CLASS" 
                                    class="btn-primary btn-lg w-100" icon="fa-users" 
                                    style="height: 100px; font-size: 18px;"/>
                        </div>
                        <div class="col-6">
                            <button name="action_create_service" type="object" string="ADD SERVICE" 
                                    class="btn-warning btn-lg w-100" icon="fa-user" 
                                    style="height: 100px; font-size: 18px;"/>
                        </div>
                    </div>
                </sheet>
                <footer>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
