<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_gym_checkin_wizard_form" model="ir.ui.view">
        <field name="name">gym.checkin.wizard.form</field>
        <field name="model">gym.checkin.wizard</field>
        <field name="arch" type="xml">
            <form string="Check-in Member" style="width: 500px;">
                <group>
                    <group>
                        <field name="member_id" readonly="1"/>
                        <field name="subscription_id" invisible="1"/>
                        <field name="membership_name" string="Active Membership"/>
                    </group>
                    <!-- <group>
                        <field name="door_id" options="{'no_create': True}"/>
                        <field name="method"/>
                    </group> -->
                </group>
                <footer>
                    <button name="action_confirm" string="Check In" type="object" class="oe_highlight" confirm="Confirm check in?"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_gym_checkin_wizard" model="ir.actions.act_window">
        <field name="name">Check-in</field>
        <field name="res_model">gym.checkin.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
