<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_gym_payment_details_report_wizard_form" model="ir.ui.view">
        <field name="name">gym.payment.details.report.wizard.form</field>
        <field name="model">gym.payment.details.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Payment Details Report">
                <sheet>
                    <group>
                        <group>
                            <field name="report_date"/>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button string="Export Excel" type="object" name="action_export_xlsx" class="oe_highlight"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_gym_payment_details_report_wizard" model="ir.actions.act_window">
        <field name="name">Payment Details Report</field>
        <field name="res_model">gym.payment.details.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_gym_payment_details_report_wizard_form"/>
        <field name="target">new</field>
    </record>
</odoo>
