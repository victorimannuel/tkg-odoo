<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_gym_class_enrollment_create_wizard_form" model="ir.ui.view">
        <field name="name">gym.class.enrollment.create.wizard.form</field>
        <field name="model">gym.class.enrollment.create.wizard</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="session_id" readonly="1" invisible="1"/>
                            <field name="class_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="has_class_benefit" invisible="1"/>
                            <field name="price"/>
                        </group>
                    </group>
                    <div invisible="not has_class_benefit" class="alert alert-success">
                        <i class="fa fa-check-circle me-1"/>
                        This member's membership covers this class. Price is set to 0.
                    </div>
                    <separator string="Member"/>
                    <group>
                        <field name="is_new_member" widget="boolean_toggle"/>
                    </group>
                    <group invisible="is_new_member">
                        <field name="member_id" options="{'no_create': False, 'no_open': True}" required="not is_new_member"/>
                    </group>
                    <group invisible="not is_new_member">
                        <group>
                            <field name="firstname" required="is_new_member" placeholder="First Name"/>
                            <field name="surname" placeholder="Last Name"/>
                            <field name="date_of_birth" placeholder="Date of Birth"/>
                            <field name="gender" placeholder="Gender" required="is_new_member"/>
                            <field name="comment" placeholder="Note"/>
                        </group>
                        <group>
                            <field name="email" placeholder="Email"/>
                            <field name="phone" required="is_new_member" placeholder="Phone"/>
                            <field name="image_1920" widget="camera_image" nolabel="0" options="{'preview_image': 'image_1920'}" required="is_new_member"/>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button name="action_confirm" string="Confirm &amp; Enroll" type="object" class="oe_highlight"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
