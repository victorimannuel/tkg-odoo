<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_referrer" model="ir.ui.view">
        <field name="name">sale.order.form.referrer</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                 <button name="action_open_apply_credit_wizard" 
                        string="Apply Referrer Credit" 
                        type="object" 
                        class="btn-secondary"
                        invisible="state != 'draft' or not partner_id"/>
            </xpath>
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="referrer_partner_id" 
                       domain="[('id', '!=', partner_id)]"
                       context="{'default_is_company': True}"
                       placeholder="Select Referrer"/>
            </xpath>
        </field>
    </record>
</odoo>
