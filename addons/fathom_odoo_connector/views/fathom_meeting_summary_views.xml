<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_fathom_meeting_summaries" model="ir.actions.act_window">
        <field name="name">Meeting Summaries</field>
        <field name="res_model">fathom.meeting.summary</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('summary_markdown', '!=', False)]</field>
    </record>

    <record id="view_fathom_meeting_summary_list" model="ir.ui.view">
        <field name="name">fathom.meeting.summary.list</field>
        <field name="model">fathom.meeting.summary</field>
        <field name="arch" type="xml">
            <list string="Meeting Summaries" create="false">
                <field name="meeting_start"/>
                <field name="name"/>
                <field name="calendar_event_id"/>
                <field name="account_id"/>
                <field name="synced_at"/>
            </list>
        </field>
    </record>

    <record id="view_fathom_meeting_summary_form" model="ir.ui.view">
        <field name="name">fathom.meeting.summary.form</field>
        <field name="model">fathom.meeting.summary</field>
        <field name="arch" type="xml">
            <form string="Meeting Summary" create="false">
                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="account_id" readonly="1"/>
                            <field name="recording_id" readonly="1"/>
                            <field name="meeting_url" readonly="1" widget="url"/>
                            <field name="share_url" readonly="1" widget="url"/>
                        </group>
                        <group col="2">
                            <field name="calendar_event_id" readonly="1"/>
                            <field name="meeting_start" readonly="1"/>
                            <field name="meeting_end" readonly="1"/>
                            <field name="source_created_at" readonly="1"/>
                            <field name="synced_at" readonly="1"/>
                        </group>
                    </group>
                    <group string="Action Items">
                        <field name="action_items_html" nolabel="1" readonly="1" widget="html" colspan="2"/>
                    </group>
                    <group string="Summary">
                        <field name="summary_html" nolabel="1" readonly="1" widget="html" colspan="2"/>
                    </group>
                    <group string="Raw Markdown">
                        <field name="summary_markdown" nolabel="1" readonly="1" widget="text" colspan="2"/>
                    </group>
                    <group string="Transcript (Raw JSON)">
                        <field name="transcript_json" nolabel="1" readonly="1" widget="text" colspan="2"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
