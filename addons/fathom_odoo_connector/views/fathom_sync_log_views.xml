<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_fathom_sync_log_tree" model="ir.ui.view">
        <field name="name">fathom.sync.log.tree</field>
        <field name="model">fathom.sync.log</field>
        <field name="arch" type="xml">
            <list>
                <field name="create_date"/>
                <field name="sync_type"/>
                <field name="status"/>
                <field name="response_status"/>
                <field name="created_count"/>
                <field name="updated_count"/>
                <field name="skipped_count"/>
                <field name="failed_count"/>
            </list>
        </field>
    </record>

    <record id="view_fathom_sync_log_form" model="ir.ui.view">
        <field name="name">fathom.sync.log.form</field>
        <field name="model">fathom.sync.log</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="sync_type"/>
                            <field name="status"/>
                            <field name="response_status"/>
                        </group>
                        <group>
                            <field name="created_count"/>
                            <field name="updated_count"/>
                            <field name="skipped_count"/>
                            <field name="failed_count"/>
                            <field name="retry_count"/>
                        </group>
                    </group>
                    <group>
                        <field name="request_path"/>
                        <field name="request_payload" widget="text"/>
                        <field name="response_body" widget="text"/>
                        <field name="error_message" widget="text"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_fathom_sync_log" model="ir.actions.act_window">
        <field name="name">Fathom Sync Logs</field>
        <field name="res_model">fathom.sync.log</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
