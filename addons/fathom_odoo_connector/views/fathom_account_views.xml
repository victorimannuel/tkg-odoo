<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_fathom_account_tree" model="ir.ui.view">
        <field name="name">fathom.account.tree</field>
        <field name="model">fathom.account</field>
        <field name="arch" type="xml">
            <list>
                <field name="active"/>
                <field name="name"/>
                <field name="user_id"/>
                <field name="company_id"/>
                <field name="sync_enabled"/>
                <field name="last_sync_at"/>
            </list>
        </field>
    </record>

    <record id="view_fathom_account_form" model="ir.ui.view">
        <field name="name">fathom.account.form</field>
        <field name="model">fathom.account</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_test_connection" type="object" string="Test Connection" class="btn-primary"/>
                    <button name="action_sync_meeting_summaries" type="object" string="Sync Meeting Summaries"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="active"/>
                            <field name="name"/>
                            <field name="user_id"/>
                            <field name="company_id"/>
                        </group>
                        <group>
                            <field name="sync_enabled"/>
                            <field name="last_sync_at" readonly="1"/>
                            <field name="connection_test_status" readonly="1"/>
                            <field name="connection_tested_at" readonly="1"/>
                        </group>
                    </group>
                    <group string="Credentials">
                        <field name="api_base_url"/>
                        <field name="api_key" password="True"/>
                    </group>
                    <group string="Last Test">
                        <field name="connection_test_message" nolabel="1" widget="text" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_fathom_account" model="ir.actions.act_window">
        <field name="name">Fathom Accounts</field>
        <field name="res_model">fathom.account</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_my_accounts': 1}</field>
    </record>

    <record id="view_fathom_account_search" model="ir.ui.view">
        <field name="name">fathom.account.search</field>
        <field name="model">fathom.account</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="user_id"/>
                <filter string="My Accounts" name="my_accounts" domain="[('user_id', '=', uid)]"/>
                <filter string="Enabled" name="enabled" domain="[('sync_enabled', '=', True)]"/>
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
            </search>
        </field>
    </record>
</odoo>
