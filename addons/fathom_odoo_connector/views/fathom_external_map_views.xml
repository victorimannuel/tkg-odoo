<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_fathom_external_map_tree" model="ir.ui.view">
        <field name="name">fathom.external.map.tree</field>
        <field name="model">fathom.external.map</field>
        <field name="arch" type="xml">
            <list>
                <field name="model"/>
                <field name="external_id"/>
                <field name="res_id"/>
                <field name="source_updated_at"/>
                <field name="last_synced_at"/>
            </list>
        </field>
    </record>

    <record id="view_fathom_external_map_form" model="ir.ui.view">
        <field name="name">fathom.external.map.form</field>
        <field name="model">fathom.external.map</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name" readonly="1"/>
                        <field name="model"/>
                        <field name="external_id"/>
                        <field name="res_id"/>
                        <field name="checksum"/>
                        <field name="source_updated_at"/>
                        <field name="last_synced_at"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_fathom_external_map" model="ir.actions.act_window">
        <field name="name">Fathom External Mappings</field>
        <field name="res_model">fathom.external.map</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
